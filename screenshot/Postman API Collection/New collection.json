            ],
            "url": "{{baseUrl}}/user-details"
          }
        },
        {
          "name": "Save Address",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"Surat\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/user-details/address"
          }
        }
      ]
    },

    {
      "name": "WISHLIST",
      "item": [
        {
          "name": "Get Wishlist",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/wishlist"
          }
        },
        {
          "name": "Add Wishlist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_ID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/wishlist/add"
          }
        }
      ]
    }
  ]
}